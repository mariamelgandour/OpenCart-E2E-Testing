    {
      "name": "Module 1 — Authentication",
      "item": [
        {
          "name": "TC-001 Login — valid credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-001 | Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('TC-001 | Has api_token', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('api_token');",
                  "  pm.environment.set('api_token', j.api_token);",
                  "  console.log('Token saved:', j.api_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{api_username}}",
                  "type": "text"
                },
                {
                  "key": "key",
                  "value": "{{api_key}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/index.php?route=api/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "index.php"
              ],
              "query": [
                {
                  "key": "route",
                  "value": "api/login"
                }
              ]
            }
          },
          "response": []
        },
