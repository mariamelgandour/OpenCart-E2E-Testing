    {
      "name": "Module 4 — Order",
      "item": [
        {
          "name": "TC-014 Order — place order with all details",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const base   = pm.environment.get('base_url');",
                  "const token  = pm.environment.get('api_token');",
                  "const prodId = pm.environment.get('product_id');",
                  "const h = { 'Content-Type': 'application/x-www-form-urlencoded' };",
                  "const t = '&api_token=' + token;",
                  "pm.sendRequest({ url: base+'/index.php?route=api/cart/add'+t, method:'POST', header:h,",
                  "  body:{ mode:'urlencoded', urlencoded:[{key:'product_id',value:prodId},{key:'quantity',value:'1'}]}",
                  "}, (e,r) => console.log('Cart add:', r.json()));",
                  "pm.sendRequest({ url: base+'/index.php?route=api/customer'+t, method:'POST', header:h,",
                  "  body:{ mode:'urlencoded', urlencoded:[{key:'firstname',value:'John'},{key:'lastname',value:'Doe'},{key:'email',value:'john.doe@test.com'},{key:'telephone',value:'01000000000'}]}",
                  "}, (e,r) => console.log('Customer:', r.json()));",
                  "pm.sendRequest({ url: base+'/index.php?route=api/shipping/address'+t, method:'POST', header:h,",
                  "  body:{ mode:'urlencoded', urlencoded:[{key:'firstname',value:'John'},{key:'lastname',value:'Doe'},{key:'address_1',value:'123 Test Street'},{key:'city',value:'Cairo'},{key:'postcode',value:'12345'},{key:'country_id',value:'222'},{key:'zone_id',value:'3563'}]}",
                  "}, (e,r) => console.log('Shipping address:', r.json()));",
                  "pm.sendRequest({ url: base+'/index.php?route=api/shipping/method'+t, method:'POST', header:h,",
                  "  body:{ mode:'urlencoded', urlencoded:[{key:'shipping_method',value:'flat.flat'}]}",
                  "}, (e,r) => console.log('Shipping method:', r.json()));",
                  "pm.sendRequest({ url: base+'/index.php?route=api/payment/address'+t, method:'POST', header:h,",
                  "  body:{ mode:'urlencoded', urlencoded:[{key:'firstname',value:'John'},{key:'lastname',value:'Doe'},{key:'address_1',value:'123 Test Street'},{key:'city',value:'Cairo'},{key:'postcode',value:'12345'},{key:'country_id',value:'222'},{key:'zone_id',value:'3563'}]}",
                  "}, (e,r) => console.log('Payment address:', r.json()));",
                  "pm.sendRequest({ url: base+'/index.php?route=api/payment/method'+t, method:'POST', header:h,",
                  "  body:{ mode:'urlencoded', urlencoded:[{key:'payment_method',value:'cod'}]}",
                  "}, (e,r) => console.log('Payment method:', r.json()));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('TC-014 | Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('TC-014 | Returns order_id', () => {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('order_id');",
                  "  pm.environment.set('order_id', j.order_id);",
                  "  console.log('order_id saved:', j.order_id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": []
            },
            "url": {
              "raw": "{{base_url}}/index.php?route=api/order/add&api_token={{api_token}}",
              "host": [
